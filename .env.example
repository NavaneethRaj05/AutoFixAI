# Groq AI
GROQ_API_KEY=

# GitHub
# Option A: Personal Access Token (dev/local — simpler)
GITHUB_TOKEN=

# Option B: GitHub App (production — same auth as CodeRabbit/Mergify)
# Create app at https://github.com/settings/apps/new
# Generate & download a private key, then paste it here with \n replacing real newlines:
# openssl pkcs8 -topk8 -inform PEM -outform PEM -nocrypt -in private-key.pem | tr '\n' '\\n'
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=

# MongoDB
MONGO_URI=

# Auth
JWT_SECRET=

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Registration gate (production safety)
# Leave unset in production. Set to 'true' ONLY when creating the first admin user,
# then immediately remove it and redeploy.
# ALLOW_REGISTRATION=true
